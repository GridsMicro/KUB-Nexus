# KUB-Nexus Discord Bot Environment
# Copy this file to .env and fill in the values

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Guild (Server) ID
GUILD_ID=1480252596722729103

# Channel IDs
CHANNEL_QA=1480258562180776098
CHANNEL_BUG_REPORT=bug_report_channel_id_here
CHANNEL_FEATURE_REQUEST=feature_request_channel_id_here
CHANNEL_ANNOUNCEMENTS=announcements_channel_id_here
